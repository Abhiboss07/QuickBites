# ===== QuickBites Backend Environment =====
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production

# Database (MongoDB Atlas recommended for production)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/quickbites?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN
JWT_EXPIRE=7d

# Razorpay Payment Gateway
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# CORS (comma-separated allowed origins, leave empty if serving frontend from same origin)
CORS_ORIGINS=
