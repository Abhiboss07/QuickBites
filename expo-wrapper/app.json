{
  "expo": {
    "name": "quickbites-mobile",
    "slug": "quickbites-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "quickbites",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": "exposdk:54.0.0",
    "sdkVersion": "54.0.0",
    "updates": {
      "enabled": false
    },
    "network": {
      "timeout": 10000
    }
  }
}
